# Secrets — never commit. .env was historically tracked and leaked an
# OpenAI key (caught by GitHub push protection) plus Moz / Diffbot / AWS /
# Perplexity / Tinify credentials that leaked silently. History was
# rewritten on 2026-05-16 to scrub .env from every commit.
.env
.env.local
.env.*.local
*.pem
*.key

# Python build artifacts
__pycache__/
*.py[cod]
*$py.class
*.egg-info/

# Virtual environments
.venv/
venv/

# Claude Code state
.claude/

# OS / editor noise
.DS_Store
Thumbs.db

# JetBrains per-machine state (project files stay tracked; data-source
# files and workspace UI state are machine-specific)
.idea/dataSources.local.xml
.idea/dataSources/
.idea/data_source_mapping.xml
.idea/workspace.xml

# Recipe-pipeline runtime artifacts: every bookmarklet capture writes a PNG
# into input/, and image extracts write there too. These are inputs to the
# pipeline, not source to track. Subdirectories (e.g. input/pipeline/) are
# tracked normally — only loose image files at input/ root are ignored.
input/*.png
input/*.jpg
input/*.jpeg
input/pipeline/__pycache__/
input/__pycache__/
extract/__pycache__/
to_markdown/__pycache__/

# Generated outputs (image gen, batch results)
generated-images/
batches/
# generated/ holds AI-generated + user-uploaded recipe images. Runtime
# accumulating state, not source — created on demand by /images and
# /recipes/<id>/generate-image. App auto-mkdir's at startup.
generated/

# Logs / temp DB tools
recipe_server.log
recipe_database.db
recipes.sqbpro
# uvicorn stdio is redirected to these files by bcc_start.bat —
# regenerated every restart, never source.
uvicorn_stdout.log
uvicorn_stderr.log
# Per-job runtime logs from the async job system. The dishes form
# links to the latest via /logs/<filename>; never source.
logs/

# pycache that the existing entries missed
scripts/__pycache__/
intake/__pycache__/

# Loose capture artifacts that landed in repo root
/momsAsparagusAuGratin.png
